---
import Layout from '../layouts/BaseLayout.astro';
import HeaderComponent from "../components/common/Header.astro";
import { Image } from 'astro:assets';
import img from '../assets/astro.svg';

const pageTitle = "Promoción vigente";
const pageDescription = "Promoción válida del 1 al 31 de octubre 2024";
const title = "¡ Mes del implante !";
const subtitle = "Promoción válida del 1 al 31 de octubre 2024";
---

<Layout title={pageTitle} description={pageDescription}>
    <HeaderComponent title={title} subtitle={subtitle}>
        <Image
            src={img}
            alt="Texto"
            widths={[320, 640, 960]}
            sizes="(max-width: 768px) 100vw, 640px"
            class="w-full h-auto rounded-lg"
        />
    </HeaderComponent>
</Layout>
