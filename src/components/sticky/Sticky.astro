---
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
import logo from "../../assets/logos/logo.jpg";
const correo =
    "&#114;&#101;&#99;&#101;&#112;&#99;&#105;&#111;&#110;&#64;&#100;&#101;&#110;&#116;&#97;&#108;&#118;&#105;&#99;&#97;&#108;&#118;&#97;&#114;&#111;&#46;&#99;&#111;&#109;";
const telefono = "+34 91 760 24 40";
---

<div id="site-header" class="fixed top-0 z-50 w-full bg-gray-100 py-2 md:py-4">
    <div class="px-2 flex items-center gap-4 md:gap-8">
        <!-- Logo -->
        <div>
            <Image
                src={logo}
                alt="Logo de la clínica dental"
                width={495}
                height={106}
                class="w-25 md:w-45 lg:w-50 h-auto"
            />
        </div>

        <!-- Información -->
        <div
            class="flex items-center gap-2 sm:gap-4 whitespace-nowrap text-gray-500 font-semibold"
        >
            <div class="flex items-center gap-1">
                <Icon name="heroicons:envelope" class="w-3 h-3 md:w-4 md:h-4" />
                <a
                    href="mailto:recepcion@dentalvicalvaro.com"
                    class="text-[8px] md:text-sm"
                    set:html={correo}
                />
            </div>

            <div class="flex items-center gap-1">
                <Icon
                    name="heroicons:phone-solid"
                    class="w-3 h-3 md:w-4 md:h-4"
                />
                <a href={`tel:${telefono}`} class="text-[8px] md:text-sm">
                    {telefono}
                </a>
            </div>

            <a
                href="/contacto/#pedircita"
                class="hidden sm:block rounded-md bg-blue-500 hover:bg-blue-600 text-white font-bold whitespace-nowrap px-4 py-2 text-xs md:text-sm"
            >
                PEDIR CITA
            </a>
        </div>
    </div>
</div>
