---
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
import logo from "../../assets/logos/logo.jpg";
import { PHONE_NUMBER } from "../../data/constants";
---

<div
    id="site-header"
    class="fixed inset-x-0 top-0 z-50 bg-gray-100 py-2 md:py-4"
>
    <div
        class="max-w-5xl mx-auto flex items-center justify-center gap-8 lg:gap-12 px-4"
    >
        <!-- Logo -->
        <div class="shrink-0">
            <Image
                src={logo}
                alt="Logo de la clínica dental"
                width={495}
                height={106}
                class="w-28 md:w-40 lg:w-48 h-auto"
            />
        </div>

        <!-- Teléfono -->
        <div class="flex items-center gap-2 text-gray-500 font-semibold">
            <Icon name="heroicons:phone-solid" class="w-4 h-4" />
            <a href={`tel:${PHONE_NUMBER}`} class="text-xs md:text-sm">
                {PHONE_NUMBER}
            </a>
        </div>

        <!-- Botón -->
        <a
            href="/contacto/#pedircita"
            class="hidden sm:block rounded-md bg-blue-500 hover:bg-blue-600 text-white font-bold px-5 py-2 text-xs md:text-sm"
        >
            PEDIR CITA
        </a>
    </div>
</div>
