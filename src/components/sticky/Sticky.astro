---
import { Icon } from "astro-icon/components";
const correo =
    "&#114;&#101;&#99;&#101;&#112;&#99;&#105;&#111;&#110;&#64;&#100;&#101;&#110;&#116;&#97;&#108;&#118;&#105;&#99;&#97;&#108;&#118;&#97;&#114;&#111;&#46;&#99;&#111;&#109;";
const telefono = "+34 91 760 24 40";
---

<div
    id="site-header"
    class="md:block fixed top-0 z-50 w-full bg-gray-100 py-2 md:py-4"
>
    <div
        class="max-w-6xl mx-auto px-4 flex flex-row items-center justify-center gap-2 md:gap-0 md:justify-between"
    >
        <div
            class="font-semibold text-gray-500 flex flex-row gap-6 md:flex-row md:items-center md:gap-6"
        >
            <div class="flex items-center gap-2">
                <Icon
                    name="heroicons:envelope"
                    class="w-3 h-3 mt-1 md:mt-0 md:w-4 md:h-4"
                />
                <a
                    href="mailto:recepcion@clinicahermosilla57.com"
                    class="text-[0.6rem] md:text-sm"
                    set:html={correo}
                />
            </div>

            <div class="flex items-center gap-1">
                <Icon name="heroicons:phone" class="w-3 h-3 md:w-4 md:h-4" />
                <a href={`tel:${telefono}`} class="text-[0.6rem] md:text-sm"
                    >{telefono}</a
                >
            </div>
        </div>

        <div class="flex items-center justify-center gap-3 md:gap-4 flex-1">
            <a
                href="/contacto/#pedircita"
                class="px-6 py-1.5 bg-blue-500 hover:bg-blue-500 text-white text-xs font-bold w-full text-center md:w-auto hidden sm:block rounded-md"
            >
                PEDIR CITA
            </a>
        </div>
    </div>
</div>
